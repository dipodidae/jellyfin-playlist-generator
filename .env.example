# Playlist Generator Environment Configuration (v3)
# Copy to .env and fill in values. Never commit .env to repository.

# ═══════════════════════════════════════════════════════════════════
# DATABASE (PostgreSQL + pgvector)
# ═══════════════════════════════════════════════════════════════════
DATABASE_URL=postgresql://playlist:playlist_dev@localhost:5432/playlist_generator
POSTGRES_PASSWORD=playlist_dev

# ═══════════════════════════════════════════════════════════════════
# MUSIC LIBRARY
# ═══════════════════════════════════════════════════════════════════
# Comma-separated paths to scan for music files
MUSIC_DIRECTORIES=/music
MUSIC_PATH=/path/to/your/music  # Host path mounted to /music in container

# Scanner settings
SCAN_THREADS=8

# ═══════════════════════════════════════════════════════════════════
# M3U EXPORT
# ═══════════════════════════════════════════════════════════════════
M3U_OUTPUT_DIR=/playlists
PLAYLIST_PATH=/path/to/playlists  # Host path mounted to /playlists in container

# ═══════════════════════════════════════════════════════════════════
# SEED-ONLY SETTINGS
# The keys below are read ONCE on first boot to populate the
# app_settings database table (only when a key is not already
# present). After first boot the DB is the source of truth — edit
# these values in-app at /settings. Changing them here has no effect
# on a running instance.
# ═══════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════
# LAST.FM (required for tag enrichment & artist similarity)
# ═══════════════════════════════════════════════════════════════════
# Get API key from: https://www.last.fm/api/account/create
LASTFM_API_KEY=your-lastfm-api-key
LASTFM_API_SECRET=your-lastfm-api-secret

# ═══════════════════════════════════════════════════════════════════
# DISCOGS (optional — true original release date resolution)
# ═══════════════════════════════════════════════════════════════════
# Get token from: https://www.discogs.com/settings/developers
# Use EITHER a personal access token OR a consumer key/secret pair (token wins
# if both are set). Both authenticate the search/masters/versions endpoints.
DISCOGS_TOKEN=your-discogs-personal-access-token
DISCOGS_CONSUMER_KEY=
DISCOGS_CONSUMER_SECRET=

# ═══════════════════════════════════════════════════════════════════
# MUSICBRAINZ (required for ID resolution → album legitimacy + RYM matching)
# ═══════════════════════════════════════════════════════════════════
# A contact email is mandated by the MusicBrainz API ToS; without it lookups
# are throttled/rejected and mb_release_groups never populates.
MUSICBRAINZ_CONTACT=your-email@example.com

# ═══════════════════════════════════════════════════════════════════
# RATEYOURMUSIC (optional — ratings, votes, descriptors, high-res genres)
# ═══════════════════════════════════════════════════════════════════
# Scraping is opt-in and deliberately slow. Delays are seconds per request.
RYM_SCRAPE_ENABLED=false
RYM_SCRAPE_DELAY_MIN=2.0
RYM_SCRAPE_DELAY_MAX=5.0

# ═══════════════════════════════════════════════════════════════════
# OPENAI (optional — prompt parsing, playlist titles & track explanations)
# ═══════════════════════════════════════════════════════════════════
# Get API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# ═══════════════════════════════════════════════════════════════════
# AUTHENTICATION (required for frontend access)
# ═══════════════════════════════════════════════════════════════════
NUXT_AUTH_USERNAME=admin
NUXT_AUTH_PASSWORD=your-secure-password
NUXT_SESSION_PASSWORD=at-least-32-characters-long-random-string

# ═══════════════════════════════════════════════════════════════════
# EMBEDDINGS
# ═══════════════════════════════════════════════════════════════════
EMBEDDING_MODEL_VERSION=1

# ═══════════════════════════════════════════════════════════════════
# LEGACY (deprecated, kept for migration)
# ═══════════════════════════════════════════════════════════════════
# JELLYFIN_URL=https://jellyfin.4eva.me
# JELLYFIN_API_KEY=your-jellyfin-api-key
# JELLYFIN_USER_ID=your-jellyfin-user-id
# DATABASE_PATH=/app/data/music.duckdb
