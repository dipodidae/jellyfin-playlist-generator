# Playlist Generator Environment Configuration
# Copy to .env and fill in values. Never commit .env to repository.

# ═══════════════════════════════════════════════════════════════════
# JELLYFIN (required for library sync)
# ═══════════════════════════════════════════════════════════════════
# Get API key from: Jellyfin Dashboard → API Keys → Create
# Get User ID from: Jellyfin → Users → Click user → URL contains user ID
JELLYFIN_URL=https://jellyfin.4eva.me
JELLYFIN_API_KEY=your-jellyfin-api-key
JELLYFIN_USER_ID=your-jellyfin-user-id

# ═══════════════════════════════════════════════════════════════════
# LAST.FM (required for tag enrichment & artist similarity)
# ═══════════════════════════════════════════════════════════════════
# Get API key from: https://www.last.fm/api/account/create
LASTFM_API_KEY=your-lastfm-api-key
LASTFM_API_SECRET=your-lastfm-api-secret

# ═══════════════════════════════════════════════════════════════════
# OPENAI (required for prompt parsing)
# ═══════════════════════════════════════════════════════════════════
# Get API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# ═══════════════════════════════════════════════════════════════════
# AUTHENTICATION (required for frontend access)
# ═══════════════════════════════════════════════════════════════════
NUXT_AUTH_USERNAME=admin
NUXT_AUTH_PASSWORD=your-secure-password
NUXT_SESSION_PASSWORD=at-least-32-characters-long-random-string

# ═══════════════════════════════════════════════════════════════════
# SERVICE CONFIGURATION (defaults work for Docker)
# ═══════════════════════════════════════════════════════════════════
NUXT_MUSIC_SERVICE_URL=http://music-service:8000
DATABASE_PATH=/app/data/music.duckdb
